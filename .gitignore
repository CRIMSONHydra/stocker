*.py[cod]
*.so
*.pyd
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/
.installed.cfg

# --- Virtualenvs / env -----------------------------------------------------
.venv/
venv/
env/
.python-version
.env
.env.*
